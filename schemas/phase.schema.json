{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/phase.schema.json",
  "title": "Phase",
  "description": "A single phase in the deterministic production line.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "gate", "next"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{2}$",
      "description": "Two-digit phase identifier, e.g. \"00\"."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "gate": {
      "type": "string",
      "pattern": "^gates/check_phase_[0-9]{2}\\.sh$"
    },
    "next": {
      "type": ["string", "null"],
      "description": "Id of the next phase, or null for the terminal phase."
    }
  }
}
