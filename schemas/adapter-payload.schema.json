{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/adapter-payload.schema.json",
  "title": "AdapterPayload",
  "description": "An OFFLINE, vendor-shaped request payload. Never sent in Phase 03 (dryRun, not published).",
  "type": "object",
  "required": [
    "adapterId",
    "vendor",
    "kind",
    "videoId",
    "request",
    "liveStatus",
    "dryRun",
    "published",
    "credentialsPresent",
    "createdAt",
    "checksum"
  ],
  "properties": {
    "adapterId": { "type": "string", "minLength": 1 },
    "vendor": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["avatar-video", "generative-video", "design-graphics", "voiceover"]
    },
    "videoId": { "type": "string", "pattern": "^MIAC-[0-9]{2}$" },
    "request": { "type": "object" },
    "liveStatus": { "type": "string", "enum": ["LIVE-INTEGRATION-BLOCKED", "LIVE-READY"] },
    "dryRun": { "type": "boolean", "const": true },
    "published": { "type": "boolean", "const": false },
    "credentialsPresent": { "type": "boolean" },
    "createdAt": { "type": "string", "minLength": 1 },
    "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
