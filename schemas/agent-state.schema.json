{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/agent-state.schema.json",
  "title": "AgentState",
  "description": "Per-video agent state. In Phase 01 every agent state is mock: no real production agent has executed.",
  "type": "object",
  "required": ["stage", "assignedAgent", "note", "mock"],
  "properties": {
    "stage": {
      "type": "string",
      "enum": [
        "Not Started",
        "Researching",
        "Blueprint Ready",
        "Script Ready",
        "Voice Ready",
        "Visuals Ready",
        "Render Ready",
        "Human Review",
        "Approved",
        "Publish Ready",
        "Published",
        "Blocked"
      ]
    },
    "assignedAgent": { "type": "string", "minLength": 1 },
    "note": { "type": "string" },
    "mock": { "type": "boolean", "const": true }
  }
}
