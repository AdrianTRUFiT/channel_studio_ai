{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/video-asset.schema.json",
  "title": "VideoAsset",
  "description": "A single faceless video asset in a campaign. Phase 01 holds mock/prototype records only.",
  "type": "object",
  "required": [
    "id",
    "title",
    "summary",
    "authorityPillar",
    "targetDurationSeconds",
    "status",
    "review",
    "agentState",
    "mock"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z0-9]{2,12}-[0-9]{2,4}$" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "authorityPillar": { "type": "string", "minLength": 1 },
    "targetDurationSeconds": { "type": "integer" },
    "status": {
      "type": "string",
      "enum": [
        "Not Started",
        "Researching",
        "Blueprint Ready",
        "Script Ready",
        "Voice Ready",
        "Visuals Ready",
        "Render Ready",
        "Human Review",
        "Approved",
        "Publish Ready",
        "Published",
        "Blocked"
      ]
    },
    "review": {
      "type": "object",
      "required": ["required", "decision", "reviewer", "note"],
      "properties": {
        "required": { "type": "boolean" },
        "decision": {
          "type": "string",
          "enum": ["Pending", "Approved", "Rejected", "Not Reached"]
        },
        "reviewer": { "type": ["string", "null"] },
        "note": { "type": "string" }
      }
    },
    "agentState": { "type": "object" },
    "mock": { "type": "boolean", "const": true }
  }
}
