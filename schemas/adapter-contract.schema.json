{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/adapter-contract.schema.json",
  "title": "AdapterContract",
  "description": "Declarative contract for an external creative tool adapter. Built before any live connector.",
  "type": "object",
  "required": [
    "id",
    "vendor",
    "name",
    "kind",
    "version",
    "capabilities",
    "acceptsFrom",
    "produces",
    "credentialsEnv",
    "liveStatus",
    "liveBlockedReason",
    "docsHint"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "vendor": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["avatar-video", "generative-video", "design-graphics", "voiceover"]
    },
    "version": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "acceptsFrom": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "produces": { "type": "string", "minLength": 1 },
    "credentialsEnv": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "liveStatus": { "type": "string", "enum": ["LIVE-INTEGRATION-BLOCKED", "LIVE-READY"] },
    "liveBlockedReason": { "type": "string", "minLength": 1 },
    "docsHint": { "type": "string", "minLength": 1 }
  }
}
