{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/pass-record.schema.json",
  "title": "PassRecord",
  "description": "Machine-checkable payload embedded in records/PHASE_0N_PASS.md. Emitted only by gate scripts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phaseId",
    "phaseName",
    "status",
    "timestamp",
    "gateScript",
    "gitCommit",
    "contentHash",
    "hashedOutputs",
    "testSummary",
    "nextUnlockedPhase"
  ],
  "properties": {
    "phaseId": { "type": "string", "pattern": "^[0-9]{2}$" },
    "phaseName": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "const": "PASS" },
    "timestamp": { "type": "string", "minLength": 1 },
    "gateScript": { "type": "string", "minLength": 1 },
    "gitCommit": { "type": ["string", "null"] },
    "contentHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "hashedOutputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "testSummary": { "type": "string", "minLength": 1 },
    "nextUnlockedPhase": { "type": ["string", "null"] }
  }
}
