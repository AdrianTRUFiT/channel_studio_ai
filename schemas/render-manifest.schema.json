{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/render-manifest.schema.json",
  "title": "RenderManifest",
  "description": "Output manifest for a local Phase 02 video production run. Local-only; no external publishing occurred.",
  "type": "object",
  "required": [
    "campaignId",
    "mode",
    "rendererMode",
    "ffmpeg",
    "generatedAt",
    "count",
    "videos",
    "published",
    "disclaimer"
  ],
  "properties": {
    "campaignId": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["smoke", "full"] },
    "rendererMode": { "type": "string", "enum": ["local-mock-render", "local-frames-only-no-ffmpeg"] },
    "ffmpeg": {
      "type": "object",
      "required": ["available", "source"],
      "properties": {
        "available": { "type": "boolean" },
        "source": { "type": "string" },
        "version": { "type": ["string", "null"] }
      }
    },
    "generatedAt": { "type": "string", "minLength": 1 },
    "count": { "type": "integer" },
    "published": { "type": "boolean", "const": false },
    "disclaimer": { "type": "string", "minLength": 1 },
    "videos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "videoId",
          "title",
          "sourceCampaignId",
          "outputPath",
          "durationSeconds",
          "status",
          "fileHash",
          "fileBytes",
          "createdAt",
          "rendererMode",
          "disclaimer"
        ],
        "properties": {
          "videoId": { "type": "string", "pattern": "^MIAC-[0-9]{2}$" },
          "title": { "type": "string", "minLength": 1 },
          "sourceCampaignId": { "type": "string", "minLength": 1 },
          "outputPath": { "type": "string", "minLength": 1 },
          "durationSeconds": { "type": "integer" },
          "status": { "type": "string", "enum": ["rendered", "blocked-no-ffmpeg"] },
          "fileHash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "fileBytes": { "type": "integer" },
          "createdAt": { "type": "string", "minLength": 1 },
          "rendererMode": {
            "type": "string",
            "enum": ["local-mock-render", "local-frames-only-no-ffmpeg"]
          },
          "disclaimer": { "type": "string", "minLength": 1 },
          "scenes": { "type": "integer" }
        }
      }
    }
  }
}
