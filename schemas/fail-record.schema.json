{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "channel-studio-ai/schemas/fail-record.schema.json",
  "title": "FailRecord",
  "description": "Machine-checkable payload embedded in records/PHASE_0N_FAIL.md. Emitted after repair attempts are exhausted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phaseId",
    "phaseName",
    "status",
    "timestamp",
    "gateScript",
    "failingCommand",
    "errorOutput",
    "attemptedRepairs",
    "suspectedCause",
    "recommendedNextAction"
  ],
  "properties": {
    "phaseId": { "type": "string", "pattern": "^[0-9]{2}$" },
    "phaseName": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "const": "FAIL" },
    "timestamp": { "type": "string", "minLength": 1 },
    "gateScript": { "type": "string", "minLength": 1 },
    "failingCommand": { "type": "string", "minLength": 1 },
    "errorOutput": { "type": "string" },
    "attemptedRepairs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suspectedCause": { "type": "string", "minLength": 1 },
    "recommendedNextAction": { "type": "string", "minLength": 1 }
  }
}
