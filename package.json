{
  "name": "channel-studio-ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Channel Studio AI — a governed faceless video production runtime. Claude processes. Code governs. Records prove. Hooks block.",
  "engines": {
    "node": ">=22.6.0"
  },
  "workspaces": [
    "web"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "node --test",
    "orchestrate": "node orchestrator/runner.ts",
    "status": "node orchestrator/runner.ts status",
    "dev": "npm run dev --workspace web",
    "build:web": "npm run build --workspace web",
    "preview": "npm run preview --workspace web",
    "produce:videos": "node scripts/produce_videos.ts",
    "produce:videos:smoke": "node scripts/produce_videos.ts --smoke",
    "gate:00": "bash gates/check_phase_00.sh",
    "gate:01": "bash gates/check_phase_01.sh",
    "gate:02": "bash gates/check_phase_02.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ffmpeg-static": "^5.2.0",
    "typescript": "^5.7.2"
  }
}
