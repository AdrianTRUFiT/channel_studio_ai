:root {
  color: #172033;
  background: #f6f7fb;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: #f6f7fb;
}

button {
  font: inherit;
}

.app-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 280px 1fr;
}

.sidebar {
  background: #0d1320;
  color: white;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.brand-block {
  display: flex;
  align-items: center;
  gap: 14px;
}

.brand-mark {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: linear-gradient(135deg, #6d5dfc, #22c55e);
  display: grid;
  place-items: center;
  font-weight: 900;
}

.brand-block h1 {
  margin: 0;
  font-size: 18px;
}

.brand-block p {
  margin: 2px 0 0;
  color: #9aa8bd;
  font-size: 12px;
}

.nav-list {
  display: grid;
  gap: 8px;
}

.nav-item {
  border: 0;
  background: transparent;
  color: #b8c3d5;
  border-radius: 14px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
}

.nav-item:hover,
.nav-item.active {
  background: #1b2638;
  color: white;
}

.side-card {
  margin-top: auto;
  border: 1px solid #27344a;
  border-radius: 18px;
  padding: 16px;
  display: grid;
  gap: 6px;
}

.side-card span {
  color: #9aa8bd;
  font-size: 12px;
}

.main-panel {
  padding: 28px;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26px;
}

.eyebrow {
  margin: 0 0 6px;
  color: #6b7280;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.topbar h2 {
  margin: 0;
  font-size: 28px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}

.metric-card,
.record-card,
.wide-card,
.empty {
  background: white;
  border: 1px solid #e3e7ef;
  border-radius: 22px;
  padding: 20px;
  box-shadow: 0 10px 25px rgba(15, 23, 42, 0.04);
}

.metric-card strong {
  font-size: 30px;
  display: block;
}

.metric-card span {
  color: #6b7280;
  font-size: 13px;
}

.wide-card {
  grid-column: 1 / -1;
}

.card-list {
  display: grid;
  gap: 16px;
}

.record-card h3 {
  margin: 12px 0 8px;
  font-size: 18px;
}

.record-card p {
  margin: 0;
  color: #5d6678;
  line-height: 1.5;
}

.record-head,
.record-meta,
.button-row,
.check-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}

.record-head {
  justify-content: space-between;
}

.score {
  background: #eef2ff;
  color: #4338ca;
  border-radius: 999px;
  padding: 6px 10px;
  font-weight: 900;
  font-size: 13px;
}

.status {
  background: #f3f4f6;
  color: #374151;
  border-radius: 999px;
  padding: 6px 10px;
  font-weight: 800;
  font-size: 11px;
  text-transform: uppercase;
}

.status.in_production,
.status.ready_for_review,
.status.dave_verified {
  background: #fff7ed;
  color: #c2410c;
}

.status.published {
  background: #ecfdf5;
  color: #047857;
}

.record-meta {
  margin: 16px 0;
}

.record-meta span,
.check-row span {
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 7px 10px;
  color: #4b5563;
  font-size: 12px;
  font-weight: 700;
}

.check-row {
  margin: 16px 0;
}

.check-row span.done {
  background: #ecfdf5;
  color: #047857;
  border-color: #bbf7d0;
}

.primary,
.secondary {
  border: 0;
  border-radius: 12px;
  padding: 10px 14px;
  font-weight: 800;
  cursor: pointer;
}

.primary {
  background: #4f46e5;
  color: white;
}

.secondary {
  background: white;
  color: #1f2937;
  border: 1px solid #d8dee9;
}

.primary:disabled,
.secondary:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.log-list {
  margin-top: 16px;
  display: grid;
  gap: 8px;
}

.log-item {
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  padding: 10px;
  border-radius: 12px;
  color: #4b5563;
  font-size: 13px;
}

pre {
  overflow: auto;
  background: #0d1320;
  color: #d7e1f0;
  padding: 16px;
  border-radius: 14px;
}

@media (max-width: 900px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    min-height: auto;
  }

  .grid {
    grid-template-columns: 1fr;
  }
}
